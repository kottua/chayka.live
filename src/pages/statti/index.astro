---
import Layout from '../../components/layout/Layout.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import { getArticles } from '../../lib/data';

const articles = await getArticles();
---

<Layout title="Статті" description="База знань із відповідями на конкретні психологічні запити." canonicalPath="/statti">
  <Breadcrumbs items={[{ label: 'Статті' }]} />
  <section class="section">
    <div class="container">
      <p class="eyebrow">Статті</p>
      <h1 class="mt-4 text-4xl font-semibold leading-tight md:text-5xl">База знань</h1>
      <div class="mt-10 grid gap-4 md:grid-cols-2">
        {articles.map((article) => (
          <a class="rounded-lg border border-[var(--color-line)] bg-[var(--color-surface)] p-5 hover:border-[var(--color-accent)]" href={`/statti/${article.slug}`}>
            <h2 class="text-lg font-semibold">{article.title}</h2>
            <p class="mt-3 text-sm leading-6 text-[var(--color-muted)]">{article.excerpt}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
