---
import Layout from '../../components/layout/Layout.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import { getServices } from '../../lib/data';

const services = await getServices();
---

<Layout title="Послуги" description="Напрямки роботи психотерапевта з окремими SEO-сторінками під кожну послугу." canonicalPath="/poslugy">
  <Breadcrumbs items={[{ label: 'Послуги' }]} />
  <section class="section">
    <div class="container">
      <p class="eyebrow">Послуги</p>
      <h1 class="mt-4 text-4xl font-semibold leading-tight md:text-5xl">Напрямки роботи</h1>
      <div class="mt-10 grid gap-4 md:grid-cols-3">
        {services.map((service) => (
          <a class="rounded-lg border border-[var(--color-line)] bg-[var(--color-surface)] p-5 hover:border-[var(--color-accent)]" href={`/poslugy/${service.slug}`}>
            <h2 class="text-lg font-semibold">{service.title}</h2>
            <p class="mt-3 text-sm leading-6 text-[var(--color-muted)]">{service.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
