---
import Layout from '../../components/layout/Layout.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import { getConcerns } from '../../lib/data';

const concerns = await getConcerns();
---

<Layout title="Запити" description="SEO-сторінки під конкретні психологічні запити і стани." canonicalPath="/zapyt">
  <Breadcrumbs items={[{ label: 'Запити' }]} />
  <section class="section">
    <div class="container">
      <p class="eyebrow">Запити</p>
      <h1 class="mt-4 text-4xl font-semibold leading-tight md:text-5xl">Конкретні теми, з якими люди шукають підтримку</h1>
      <div class="mt-10 grid gap-4 md:grid-cols-3">
        {concerns.map((concern) => (
          <a class="rounded-lg border border-[var(--color-line)] bg-[var(--color-surface)] p-5 hover:border-[var(--color-accent)]" href={`/zapyt/${concern.slug}`}>
            <h2 class="text-lg font-semibold">{concern.title}</h2>
            <p class="mt-3 text-sm leading-6 text-[var(--color-muted)]">{concern.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
