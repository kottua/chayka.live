---
import Layout from '../components/layout/Layout.astro';
import GlobalCTA from '../components/cta/GlobalCTA.astro';
import {
  getArticles,
  getConcerns,
  getContactSettings,
  getDefaultCTA,
  getServices,
} from '../lib/data';

const [articles, concerns, contactSettings, defaultCTA, services] = await Promise.all([
  getArticles(),
  getConcerns(),
  getContactSettings(),
  getDefaultCTA(),
  getServices(),
]);
---

<Layout
  title="Психотерапія онлайн"
  description="chayka.live - SEO-first сайт психотерапевта з послугами, запитами, статтями і м'яким першим контактом."
  canonicalPath="/"
>
  <section class="section">
    <div class="container grid gap-10 md:grid-cols-[1.1fr_0.9fr] md:items-center">
      <div>
        <p class="eyebrow">Психотерапія онлайн</p>
        <h1 class="mt-4 max-w-3xl text-4xl font-semibold leading-tight md:text-6xl">
          Простір для розмови про те, що всередині вже давно потребує уваги
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-[var(--color-muted)]">
          Сайт спроєктований як майбутня SEO-система: послуги, конкретні запити, статті, FAQ і делікатний шлях до першого контакту.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="focus-ring inline-flex min-h-12 items-center rounded-md bg-[var(--color-accent)] px-5 font-semibold text-white hover:bg-[var(--color-accent-strong)]" href="/zapys-na-konsultatsiiu">
            Звернутися
          </a>
          <a class="focus-ring inline-flex min-h-12 items-center rounded-md border border-[var(--color-line)] bg-white px-5 font-semibold hover:border-[var(--color-accent)]" href="/poslugy">
            Подивитись послуги
          </a>
        </div>
      </div>
      <div class="rounded-lg border border-[var(--color-line)] bg-[var(--color-surface)] p-6">
        <p class="text-sm font-semibold text-[var(--color-accent-strong)]">Архітектурний фокус</p>
        <ul class="mt-4 grid gap-3 text-sm leading-6 text-[var(--color-muted)]">
          <li>SEO-сторінки під конкретні психологічні запити.</li>
          <li>Sanity CMS для контенту, CTA, контактів і A/B-варіантів.</li>
          <li>GTM-ready події для месенджерів, телефону і sticky CTA.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section bg-[var(--color-surface)]">
    <div class="container">
      <p class="eyebrow">Напрямки</p>
      <h2 class="mt-3 text-3xl font-semibold">Послуги</h2>
      <div class="mt-8 grid gap-4 md:grid-cols-3">
        {services.map((service) => (
          <a class="rounded-lg border border-[var(--color-line)] bg-white p-5 hover:border-[var(--color-accent)]" href={`/poslugy/${service.slug}`}>
            <h3 class="text-lg font-semibold">{service.title}</h3>
            <p class="mt-3 text-sm leading-6 text-[var(--color-muted)]">{service.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid gap-10 md:grid-cols-2">
      <div>
        <p class="eyebrow">Запити</p>
        <h2 class="mt-3 text-3xl font-semibold">Сторінки під конкретний пошуковий намір</h2>
        <div class="mt-8 grid gap-4">
          {concerns.map((concern) => (
            <a class="rounded-lg border border-[var(--color-line)] bg-[var(--color-surface)] p-5 hover:border-[var(--color-accent)]" href={`/zapyt/${concern.slug}`}>
              <h3 class="font-semibold">{concern.title}</h3>
              <p class="mt-2 text-sm leading-6 text-[var(--color-muted)]">{concern.description}</p>
            </a>
          ))}
        </div>
      </div>
      <div>
        <p class="eyebrow">База знань</p>
        <h2 class="mt-3 text-3xl font-semibold">Перші статті</h2>
        <div class="mt-8 grid gap-4">
          {articles.map((article) => (
            <a class="rounded-lg border border-[var(--color-line)] bg-[var(--color-surface)] p-5 hover:border-[var(--color-accent)]" href={`/statti/${article.slug}`}>
              <h3 class="font-semibold">{article.title}</h3>
              <p class="mt-2 text-sm leading-6 text-[var(--color-muted)]">{article.excerpt}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <GlobalCTA placement="home_final" pageType="home" contactSettings={contactSettings} cta={defaultCTA} />
</Layout>
