---
import { icons } from '@iconify-json/simple-icons';

interface Props {
  name: string;
  size?: number;
}

const { name, size = 22 } = Astro.props;
const iconSet = icons as {
  width?: number;
  height?: number;
  icons: Record<string, { body: string; width?: number; height?: number }>;
};
const icon = iconSet.icons[name];

if (!icon) {
  throw new Error(`Missing Iconify simple-icons icon: ${name}`);
}

const width = icon.width || iconSet.width || 24;
const height = icon.height || iconSet.height || 24;
---

<svg
  aria-hidden="true"
  width={size}
  height={size}
  viewBox={`0 0 ${width} ${height}`}
  fill="none"
  focusable="false"
>
  <Fragment set:html={icon.body} />
</svg>
