---
const navItems = [
  { label: 'Про мене', href: '/pro-mene' },
  { label: 'Послуги', href: '/poslugy' },
  { label: 'Запити', href: '/zapyt/postiina-tryvoha' },
  { label: 'Статті', href: '/statti' },
  { label: 'FAQ', href: '/faq' },
];
---

<header class="border-b border-[var(--color-border)] bg-[var(--color-surface)]/90 backdrop-blur">
  <div class="container flex min-h-16 items-center justify-between gap-6">
    <a class="focus-ring text-lg font-semibold" href="/" aria-label="chayka.live home">chayka.live</a>
    <nav class="hidden items-center gap-5 text-sm text-[var(--color-muted)] md:flex" aria-label="Основна навігація">
      {navItems.map((item) => <a class="focus-ring hover:text-[var(--color-ink)]" href={item.href}>{item.label}</a>)}
    </nav>
    <a
      class="button-primary focus-ring inline-flex items-center justify-center px-4 text-sm"
      href="/zapys-na-konsultatsiiu"
      data-event="header_cta_click"
      data-placement="header"
    >
      Звернутися
    </a>
  </div>
</header>
