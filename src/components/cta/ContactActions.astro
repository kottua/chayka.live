---
import { Phone } from '@lucide/astro';
import { contactSettings as defaultContactSettings } from '../../lib/site';
import type { ContactSettings } from '../../lib/data';
import IconifyBrandIcon from '../icons/IconifyBrandIcon.astro';

interface Props {
  placement: string;
  pageType: string;
  contentId?: string;
  contactSettings?: ContactSettings;
  enabledChannels?: string[];
  ctaId?: string;
  trackingContext?: string;
}

const {
  placement,
  pageType,
  contentId = '',
  contactSettings = defaultContactSettings,
  enabledChannels,
  ctaId = '',
  trackingContext = '',
} = Astro.props;

const contactChannelIds = contactSettings.channels
  .filter((channel) => channel.role === 'contact' || channel.role === 'both')
  .map((channel) => channel.id);
const allowedChannels = enabledChannels?.length ? enabledChannels : [...contactChannelIds, 'phone'];
const actionChannels = contactSettings.channels.filter(
  (channel) =>
    allowedChannels.includes(channel.id) && (channel.role === 'contact' || channel.role === 'both'),
);
const showPhone = allowedChannels.includes('phone');
---

<div class="flex flex-wrap gap-3" data-contact-actions>
  {
    actionChannels.map((channel) => (
      <a
        class="icon-button focus-ring inline-flex items-center justify-center"
        href={channel.href}
        aria-label={`Написати у ${channel.label}`}
        title={channel.label}
        data-event="cta_contact_click"
        data-channel={channel.id}
        data-placement={placement}
        data-page-type={pageType}
        data-content-id={contentId}
        data-cta-id={ctaId}
        data-tracking-context={trackingContext}
      >
        <IconifyBrandIcon name={channel.icon} />
      </a>
    ))
  }
  {
    showPhone && (
      <button
        class="phone-reveal-button icon-button focus-ring inline-flex items-center justify-center text-sm font-semibold"
        type="button"
        aria-label="Показати номер телефону"
        title="Показати номер телефону"
        data-phone-reveal
        data-phone={contactSettings.phone}
        data-phone-display={contactSettings.phoneDisplay}
        data-event="phone_reveal"
        data-channel="phone"
        data-placement={placement}
        data-page-type={pageType}
        data-content-id={contentId}
        data-cta-id={ctaId}
        data-tracking-context={trackingContext}
      >
        <Phone size={22} stroke-width={1.8} aria-hidden="true" />
      </button>
    )
  }
</div>

<script>
  const pushEvent = (eventName, payload = {}) => {
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: eventName, ...payload });
  };

  document.querySelectorAll('[data-phone-reveal]').forEach((button) => {
    button.addEventListener('click', async () => {
      const phone = button.dataset.phone || '';
      const display = button.dataset.phoneDisplay || phone;

      if (button.dataset.revealed === 'true' && phone) {
        window.location.href = `tel:${phone}`;
        return;
      }

      button.textContent = display;
      button.dataset.revealed = 'true';
      button.setAttribute('aria-label', `Телефон: ${display}`);
      button.setAttribute('title', display);

      if (navigator.clipboard && phone) {
        await navigator.clipboard.writeText(phone);
        pushEvent('phone_copy', {
          placement: button.dataset.placement,
          page_type: button.dataset.pageType,
          content_id: button.dataset.contentId,
          cta_id: button.dataset.ctaId,
          tracking_context: button.dataset.trackingContext,
        });
      }
    });
  });
</script>
